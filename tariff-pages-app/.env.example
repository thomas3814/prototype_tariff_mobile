# Optional. Set this when the Pages site URL is not the standard https://<owner>.github.io/<repo>/ pattern.
VITE_GITHUB_REPOSITORY=

# Default branch that receives the Excel replacement commit on GitHub.
VITE_GITHUB_BRANCH=main

# Path of the single Excel source file inside the repository.
VITE_GITHUB_SOURCE_FILE_PATH=source-data/tariff-source.xlsx
